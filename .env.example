# ─── Z.AI GLM (primary AI provider) ──────────────────────────────────────────
# Get key from https://z.ai → API Platform
# Without this key, the app runs in MOCK mode (returns canned fixtures from tests/fixtures/glm/)
ZAI_API_KEY=
ZAI_API_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL_PRIMARY=glm-4.6
ZAI_MODEL_FAST=glm-4.5-flash

# Toggle GLM mock mode explicitly (overrides ZAI_API_KEY presence)
# Set to "true" during dev/test when no key is available; "false" to force real calls.
GLM_MOCK_MODE=true

# ─── ILMU (Malaysian sovereign AI — YTL AI Labs × Universiti Malaya) ────────
# Used for the coordinator briefing when USE_ILMU_FOR_BRIEFING=true.
# Sign up at https://console.ilmu.ai to get a key. OpenAI-compatible.
# When ILMU_API_KEY is empty AND USE_ILMU_FOR_BRIEFING=true, the briefing falls
# back to the same fixtures as GLM (no crash).
ILMU_API_KEY=
ILMU_API_BASE_URL=https://api.ilmu.ai/v1
USE_ILMU_FOR_BRIEFING=false

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Upstash Redis (optional — for rate limiting + prompt cache) ────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Sentry (optional) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
