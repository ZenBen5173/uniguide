node_modules/
.next/
.vercel/
dist/
out/

# env
.env
.env.local
.env.*.local

# Hackathon source documents
# .pdf and .docx are ignored everywhere by default, but anything inside docs/
# (including subfolders like docs/Hackathon Info/) is tracked — that's where
# the submitted PRD/SAD/QATD PDFs live and where the official UMHackathon
# briefs are kept for reference.
*.docx
*.pdf
!docs/**/*.pdf
!docs/**/*.docx
!tests/fixtures/sample-documents/*.pdf

# IDE
.vscode/
.idea/

# Claude Code per-user runtime files (local-only)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# OS
.DS_Store
Thumbs.db
desktop.ini

# Microsoft Office lock files (auto-created when a doc is open in Word/Excel)
~$*

# Testing
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo
next-env.d.ts
